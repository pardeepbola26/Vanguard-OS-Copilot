# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — it will never be committed.

# ---- Required ----
# OpenAI API key. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ---- Optional (local dev) ----
# Set only if you want different bind/port from defaults.
# Local defaults: HOST=127.0.0.1, PORT=8000, RELOAD=true
# HOST=127.0.0.1
# PORT=8000
# RELOAD=true

# ---- Optional (production / cloud deploy) ----
# Set these on Render/Railway/Fly to enable HTTP Basic Auth.
# If either is unset, auth is disabled (good for local dev).
# Choose a strong password — any browser visitor must enter these to access the app.
# BASIC_AUTH_USER=your-username
# BASIC_AUTH_PASS=your-strong-password

# ---- Future ----
# If you migrate to Claude, uncomment:
# ANTHROPIC_API_KEY=sk-ant-...
